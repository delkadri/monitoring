UPTIME_KUMA_PORT=3001
BESZEL_PORT=8090

# Mets ici l'URL publique ou privée que tu utiliseras pour Beszel.
# Exemple: https://beszel.ton-domaine.fr
BESZEL_APP_URL=https://beszel.delkadri.com

# L'agent Beszel utilise le hub local par defaut.
BESZEL_HUB_URL=http://127.0.0.1:8090

# A renseigner apres creation du systeme dans l'interface Beszel.
BESZEL_AGENT_TOKEN=
BESZEL_AGENT_KEY=

# Exclut les conteneurs de monitoring pour ne pas polluer les graphes.
BESZEL_EXCLUDE_CONTAINERS=uptime-kuma,beszel,beszel-agent
